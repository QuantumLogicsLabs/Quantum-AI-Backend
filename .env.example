# Server
NODE_ENV=development
PORT=5001
API_PREFIX=/api/v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/quantum-ai

# Groq AI (https://console.groq.com/docs/overview)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_COMPLETION_TOKENS=4096

# Auth — Quantum AI issues its own JWTs (iss=quantum-ai) via /auth/register and /auth/login.
# Legacy QuantumChat tokens (same JWT_SECRET, iss omitted or quantum-chat) are still accepted.
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ISSUER=quantum-ai
QUANTUM_AI_SERVICE_SECRET=change_this_to_a_second_long_random_shared_secret
# Set true in production so anonymous X-User-Id access is denied
AUTH_REQUIRED=false

# Uploads
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
# Use a dedicated Shared Drive folder; share it only with this service account.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
MAX_EXTRACTED_TEXT_CHARS=500000
MAX_FILE_SIZE_MB=25
MAX_FILES_PER_REQUEST=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=30
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# CORS (comma-separated origins) — include Quantum AI UI (5175)
CORS_ORIGIN=http://localhost:5173,http://localhost:5175

# Live web search uses free providers (DuckDuckGo + Reddit JSON + Invidious) — no API key required

# Logging
LOG_LEVEL=info
